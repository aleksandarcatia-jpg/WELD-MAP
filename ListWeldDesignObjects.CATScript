Function DescribeModelObject(obj)
    Dim nameValue
    Dim typeValue
    Dim partNumber

    nameValue = ObjectName(obj)
    typeValue = ObjectTypeName(obj)
    partNumber = ""

    On Error Resume Next
    partNumber = CStr(obj.PartNumber)
    If Err.Number <> 0 Then
        Err.Clear
        partNumber = CStr(obj.ReferenceProduct.PartNumber)
    End If
    If Err.Number <> 0 Then
        Err.Clear
        partNumber = ""
    End If
    On Error GoTo 0

    If partNumber <> "" Then
        DescribeModelObject = partNumber & " (" & typeValue & ": " & nameValue & ")"
    Else
        DescribeModelObject = typeValue & ": " & nameValue
    End If
End Function

Function CandidateValue(obj, names)
    Dim value
    value = ParameterValueByNames(obj, names)

    If value = "" Then value = DirectWeldPropertyValue(obj, names)

    CandidateValue = value
End Function

Function DirectWeldPropertyValue(obj, names)
    DirectWeldPropertyValue = ""

    Dim i
    Dim n

    For i = LBound(names) To UBound(names)
        n = NormalizeName(names(i))

        If n = "WELDTYPE" Or n = "TYPE" Then
            DirectWeldPropertyValue = DirectTypeValue(obj)
        ElseIf n = "WELDSIZE" Or n = "SIZE" Or n = "THROAT" Then
            DirectWeldPropertyValue = DirectSizeValue(obj)
        ElseIf n = "WELDLENGTH" Or n = "LENGTH" Then
            DirectWeldPropertyValue = DirectLengthValue(obj)
        End If

        If DirectWeldPropertyValue <> "" Then Exit Function
    Next
End Function

Function DirectTypeValue(obj)
    On Error Resume Next
    DirectTypeValue = CStr(obj.WeldType)
    If Err.Number <> 0 Then
        Err.Clear
        DirectTypeValue = CStr(obj.Type)
    End If
    If Err.Number <> 0 Then
        Err.Clear
        DirectTypeValue = ""
    End If
    On Error GoTo 0
End Function

Function DirectSizeValue(obj)
    On Error Resume Next
    DirectSizeValue = CStr(obj.WeldSize)
    If Err.Number <> 0 Then
        Err.Clear
        DirectSizeValue = CStr(obj.Size)
    End If
    If Err.Number <> 0 Then
        Err.Clear
        DirectSizeValue = ""
    End If
    On Error GoTo 0
End Function

Function DirectLengthValue(obj)
    On Error Resume Next
    DirectLengthValue = CStr(obj.WeldLength)
    If Err.Number <> 0 Then
        Err.Clear
        DirectLengthValue = CStr(obj.Length.Value)
    End If
    If Err.Number <> 0 Then
        Err.Clear
        DirectLengthValue = CStr(obj.Length)
    End If
    If Err.Number <> 0 Then
        Err.Clear
        DirectLengthValue = ""
    End If
    On Error GoTo 0
End Function

Function ParameterValueByNames(obj, names)
    ParameterValueByNames = ""

    Dim params
    Set params = ObjectParameters(obj)
    If params Is Nothing Then Exit Function

    Dim i
    Dim p
    Dim value

    For i = LBound(names) To UBound(names)
        Set p = Nothing
        On Error Resume Next
        Set p = params.Item(CStr(names(i)))
        If Err.Number = 0 And Not p Is Nothing Then
            value = ParameterToString(p)
            If value <> "" Then
                ParameterValueByNames = value
                On Error GoTo 0
                Exit Function
            End If
        End If
        Err.Clear
        On Error GoTo 0
    Next

    Dim j
    Dim normalizedParam
    Dim normalizedName

    For j = 1 To ParameterCount(params)
        Set p = ParameterItem(params, j)
        If Not p Is Nothing Then
            normalizedParam = NormalizeName(ObjectName(p))

            For i = LBound(names) To UBound(names)
                normalizedName = NormalizeName(names(i))
                If normalizedName <> "" Then
                    If InStr(normalizedParam, normalizedName) > 0 Then
                        value = ParameterToString(p)
                        If value <> "" Then
                            ParameterValueByNames = value
                            Exit Function
                        End If
                    End If
                End If
            Next
        End If
    Next
End Function

Sub AppendParameterReport(reportLines, obj, maxCount)
    Dim wroteAny
    wroteAny = False

    Dim params
    Set params = ObjectParameters(obj)

    If Not params Is Nothing Then
        Dim countValue
        Dim i
        Dim p
        countValue = ParameterCount(params)

        If countValue > 0 Then
            For i = 1 To countValue
                If i > CLng(maxCount) Then
                    ListAdd reportLines, "  ... parameter list truncated at " & CStr(maxCount)
                    Exit For
                End If

                Set p = ParameterItem(params, i)
                If Not p Is Nothing Then
                    ListAdd reportLines, "  PARAM " & CStr(i) & ": " & ObjectName(p) & " = " & ParameterToString(p)
                    wroteAny = True
                End If
            Next
        End If
    End If

    Call AppendUserPropertiesReport(reportLines, obj, maxCount, wroteAny)

    If Not wroteAny Then ListAdd reportLines, "  (No exposed parameters/properties read by this test macro.)"
End Sub

Sub AppendUserPropertiesReport(reportLines, obj, maxCount, ByRef wroteAny)
    Dim props
    Set props = Nothing

    On Error Resume Next
    Set props = obj.UserRefProperties
    If props Is Nothing Then Set props = obj.UserProperties
    On Error GoTo 0

    If props Is Nothing Then Exit Sub

    Dim countValue
    Dim i
    Dim p

    countValue = CollectionCount(props)

    For i = 1 To countValue
        If i > CLng(maxCount) Then
            ListAdd reportLines, "  ... property list truncated at " & CStr(maxCount)
            Exit For
        End If

        Set p = CollectionItem(props, i)
        If Not p Is Nothing Then
            ListAdd reportLines, "  PROP " & CStr(i) & ": " & ObjectName(p) & " = " & ParameterToString(p)
            wroteAny = True
        End If
    Next
End Sub

Function ObjectParameters(obj)
    Set ObjectParameters = Nothing

    On Error Resume Next
    Set ObjectParameters = obj.Parameters
    If ObjectParameters Is Nothing Then Set ObjectParameters = obj.Parent.Parameters
    If ObjectParameters Is Nothing Then Set ObjectParameters = obj.ReferenceProduct.Parameters
    On Error GoTo 0
End Function

Function ParameterCount(params)
    ParameterCount = CollectionCount(params)
End Function

Function ParameterItem(params, indexValue)
    Set ParameterItem = CollectionItem(params, indexValue)
End Function

Function CollectionCount(collection)
    CollectionCount = 0
    If collection Is Nothing Then Exit Function

    On Error Resume Next
    Err.Clear
    CollectionCount = CLng(collection.Count)
    If Err.Number <> 0 Then
        Err.Clear
        CollectionCount = CLng(collection.Count2)
    End If
    If Err.Number <> 0 Then
        Err.Clear
        CollectionCount = 0
    End If
    On Error GoTo 0
End Function

Function CollectionItem(collection, indexValue)
    Set CollectionItem = Nothing
    If collection Is Nothing Then Exit Function

    On Error Resume Next
    Set CollectionItem = collection.Item(CLng(indexValue))
    If CollectionItem Is Nothing Then Set CollectionItem = collection.Item2(CLng(indexValue))
    On Error GoTo 0
End Function

Function SelectionCount(sel)
    SelectionCount = 0
    If sel Is Nothing Then Exit Function

    On Error Resume Next
    Err.Clear
    SelectionCount = CLng(sel.Count2)
    If Err.Number <> 0 Then
        Err.Clear
        SelectionCount = CLng(sel.Count)
    End If
    If Err.Number <> 0 Then
        Err.Clear
        SelectionCount = 0
    End If
    On Error GoTo 0
End Function

Function SelectionItemValue(sel, indexValue)
    Set SelectionItemValue = Nothing
    If sel Is Nothing Then Exit Function

    Dim item
    Set item = Nothing

    On Error Resume Next
    Set item = sel.Item2(CLng(indexValue))
    If item Is Nothing Then Set item = sel.Item(CLng(indexValue))
    If Not item Is Nothing Then Set SelectionItemValue = item.Value
    On Error GoTo 0
End Function

Function ObjectName(obj)
    ObjectName = ""
    If obj Is Nothing Then Exit Function

    On Error Resume Next
    ObjectName = CStr(obj.Name)
    If Err.Number <> 0 Then
        Err.Clear
        ObjectName = CStr(obj.PartNumber)
    End If
    If Err.Number <> 0 Then
        Err.Clear
        ObjectName = ""
    End If
    On Error GoTo 0
End Function

Function ObjectTypeName(obj)
    ObjectTypeName = ""
    If obj Is Nothing Then Exit Function

    On Error Resume Next
    ObjectTypeName = TypeName(obj)
    If Err.Number <> 0 Then
        Err.Clear
        ObjectTypeName = ""
    End If
    On Error GoTo 0
End Function

Function ParentPath(obj, maxDepth)
    ParentPath = ""

    Dim current
    Set current = obj

    Dim i
    Dim part

    For i = 1 To CLng(maxDepth)
        If current Is Nothing Then Exit For

        part = ObjectTypeName(current) & ":" & ObjectName(current)
        If ParentPath = "" Then
            ParentPath = part
        Else
            ParentPath = part & " > " & ParentPath
        End If

        On Error Resume Next
        Set current = current.Parent
        If Err.Number <> 0 Then
            Err.Clear
            Set current = Nothing
        End If
        On Error GoTo 0
    Next
End Function

Function ParameterToString(parameter)
    ParameterToString = ""
    If parameter Is Nothing Then Exit Function

    On Error Resume Next
    ParameterToString = CStr(parameter.ValueAsString)
    If Err.Number <> 0 Then
        Err.Clear
        ParameterToString = CStr(parameter.Value)
    End If
    If Err.Number <> 0 Then
        Err.Clear
        ParameterToString = CStr(parameter)
    End If
    If Err.Number <> 0 Then
        Err.Clear
        ParameterToString = ""
    End If
    On Error GoTo 0
End Function

Function FirstNonEmpty(values)
    Dim i
    FirstNonEmpty = ""

    For i = LBound(values) To UBound(values)
        If Trim(CStr(values(i))) <> "" Then
            FirstNonEmpty = CStr(values(i))
            Exit Function
        End If
    Next
End Function

Function NormalizeName(value)
    Dim s
    s = UCase(CStr(value))
    s = Replace(s, " ", "")
    s = Replace(s, "_", "")
    s = Replace(s, "-", "")
    s = Replace(s, ".", "")
    s = Replace(s, "/", "")
    NormalizeName = s
End Function

Function NewList()
    Dim list
    Set list = CreateObject("Scripting.Dictionary")
    Set NewList = list
End Function

Sub ListAdd(list, value)
    list.Add CStr(list.Count), CStr(value)
End Sub

Function SafeDocumentName(doc)
    SafeDocumentName = ""
    On Error Resume Next
    SafeDocumentName = CStr(doc.FullName)
    If Err.Number <> 0 Or SafeDocumentName = "" Then
        Err.Clear
        SafeDocumentName = CStr(doc.Name)
    End If
    If Err.Number <> 0 Then
        Err.Clear
        SafeDocumentName = ""
    End If
    On Error GoTo 0
End Function

Function WriteReportFile(doc, reportLines)
    WriteReportFile = ""

    Dim folderPath
    folderPath = ReportFolder(doc)

    Dim fso
    Set fso = CreateObject("Scripting.FileSystemObject")

    If Not fso.FolderExists(folderPath) Then folderPath = DesktopFolder()

    Dim filePath
    filePath = fso.BuildPath(folderPath, REPORT_FILE_NAME)

    Dim ts
    On Error Resume Next
    Set ts = fso.CreateTextFile(filePath, True)
    If Err.Number <> 0 Or ts Is Nothing Then
        Err.Clear
        filePath = fso.BuildPath(DesktopFolder(), REPORT_FILE_NAME)
        Set ts = fso.CreateTextFile(filePath, True)
    End If

    If Not ts Is Nothing Then
        Dim i
        For i = 0 To reportLines.Count - 1
            ts.WriteLine CStr(reportLines.Item(CStr(i)))
        Next
        ts.Close
        WriteReportFile = filePath
    End If
    On Error GoTo 0
End Function

Function ReportFolder(doc)
    ReportFolder = ""

    Dim fullName
    fullName = ""

    On Error Resume Next
    fullName = CStr(doc.FullName)
    On Error GoTo 0

    If fullName <> "" Then
        Dim fso
        Set fso = CreateObject("Scripting.FileSystemObject")
        ReportFolder = fso.GetParentFolderName(fullName)
    End If

    If ReportFolder = "" Then ReportFolder = DesktopFolder()
End Function

Function DesktopFolder()
    DesktopFolder = ""

    On Error Resume Next
    DesktopFolder = CreateObject("WScript.Shell").SpecialFolders("Desktop")
    If Err.Number <> 0 Or DesktopFolder = "" Then
        Err.Clear
        DesktopFolder = CreateObject("Scripting.FileSystemObject").GetSpecialFolder(2)
    End If
    On Error GoTo 0
End Function
