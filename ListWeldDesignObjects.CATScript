Option Explicit

' ---------------------------------------------------------------------------
' ListWeldDesignObjects.CATScript
'
' Phase 1 test macro for CATIA V5 Weld Design workflow.
' It does not assign W001/W002 and does not change the model.
'
' Goal:
'   - run in an active CATProduct;
'   - find objects that look like Weld Design weld objects / Assembly Joints;
'   - list object name, type, Part A / Part B if readable, weld type/size/length
'     and exposed parameters/properties.
'
' The report is written next to the CATProduct when possible, otherwise Desktop.
' ---------------------------------------------------------------------------

Const MACRO_NAME = "ListWeldDesignObjects"
Const REPORT_FILE_NAME = "weld_design_objects_report.txt"

Sub CATMain()
    Dim doc
    Set doc = Nothing

    On Error Resume Next
    Set doc = CATIA.ActiveDocument
    On Error GoTo 0

    If doc Is Nothing Then
        MsgBox "Open CATProduct and run this macro again.", vbExclamation, MACRO_NAME
        Exit Sub
    End If

    If TypeName(doc) <> "ProductDocument" Then
        MsgBox "Active document must be CATProduct.", vbExclamation, MACRO_NAME
        Exit Sub
    End If

    Dim candidates
    Set candidates = CreateObject("Scripting.Dictionary")
    candidates.CompareMode = 1

    Call AddCandidatesFromSelectionSearch(doc, candidates)
    Call AddCandidatesFromProductTree(doc.Product, candidates)

    Dim reportLines
    Set reportLines = NewList()

    ListAdd reportLines, "CATIA Weld Design object scan"
    ListAdd reportLines, "Active document: " & SafeDocumentName(doc)
    ListAdd reportLines, "Found weld objects: " & CStr(candidates.Count)
    ListAdd reportLines, ""

    If candidates.Count = 0 Then
        ListAdd reportLines, "No Weld Design weld objects found. Use WELD_MAP fallback workflow."
    Else
        Dim key
        Dim obj
        Dim index
        index = 0

        For Each key In candidates.Keys
            index = index + 1
            Set obj = candidates.Item(key)
            Call AppendObjectReport(reportLines, obj, index)
        Next
    End If

    Dim reportPath
    reportPath = WriteReportFile(doc, reportLines)

    If candidates.Count = 0 Then
        MsgBox "No Weld Design weld objects found. Use WELD_MAP fallback workflow." & vbCrLf & _
               "Report: " & reportPath, vbExclamation, MACRO_NAME
    Else
        MsgBox "Found weld objects: " & CStr(candidates.Count) & vbCrLf & _
               "Report: " & reportPath, vbInformation, MACRO_NAME
    End If
End Sub

Sub AddCandidatesFromSelectionSearch(doc, candidates)
    Dim queries
    queries = Array( _
        "Name=*Weld*,all", _
        "Name=*WELD*,all", _
        "Name=*weld*,all", _
        "Name=*Joint*,all", _
        "Name=*JOINT*,all", _
        "Name=*Assembly*Joint*,all", _
        "Name=*Seam*,all", _
        "Name=*Welding*,all", _
        "Type=Weld,all", _
        "Type=WeldFeature,all", _
        "Type=AssemblyJoint,all", _
        "Type=Assembly Joint,all", _
        "Type=Joint,all")

    Dim i
    For i = LBound(queries) To UBound(queries)
        Call AddCandidatesFromSearchQuery(doc, candidates, CStr(queries(i)))
    Next
End Sub

Sub AddCandidatesFromSearchQuery(doc, candidates, query)
    Dim sel
    Set sel = Nothing

    On Error Resume Next
    Set sel = doc.Selection
    If sel Is Nothing Then
        On Error GoTo 0
        Exit Sub
    End If

    sel.Clear
    Err.Clear
    sel.Search CStr(query)

    If Err.Number = 0 Then
        Dim countValue
        Dim i
        Dim obj

        countValue = SelectionCount(sel)

        For i = 1 To countValue
            Set obj = SelectionItemValue(sel, i)
            If Not obj Is Nothing Then
                If IsWeldDesignCandidate(obj) Then Call AddCandidate(candidates, obj)
            End If
        Next
    End If

    Err.Clear
    sel.Clear
    On Error GoTo 0
End Sub

Sub AddCandidatesFromProductTree(product, candidates)
    If product Is Nothing Then Exit Sub

    If IsWeldDesignCandidate(product) Then Call AddCandidate(candidates, product)

    Dim children
    Set children = Nothing

    On Error Resume Next
    Set children = product.Products
    On Error GoTo 0

    If children Is Nothing Then Exit Sub

    Dim i
    Dim child

    For i = 1 To children.Count
        Set child = Nothing
        On Error Resume Next
        Set child = children.Item(i)
        On Error GoTo 0

        If Not child Is Nothing Then Call AddCandidatesFromProductTree(child, candidates)
    Next
End Sub

Function IsWeldDesignCandidate(obj)
    Dim textValue
    textValue = UCase(ObjectName(obj) & " " & ObjectTypeName(obj))

    IsWeldDesignCandidate = False

    If InStr(textValue, "WELD") > 0 Then IsWeldDesignCandidate = True
    If InStr(textValue, "WELDING") > 0 Then IsWeldDesignCandidate = True
    If InStr(textValue, "JOINT") > 0 Then IsWeldDesignCandidate = True
    If InStr(textValue, "ASSEMBLYJOINT") > 0 Then IsWeldDesignCandidate = True
    If InStr(textValue, "SEAM") > 0 Then IsWeldDesignCandidate = True
End Function

Sub AddCandidate(candidates, obj)
    Dim key
    key = CandidateKey(obj)

    If key = "" Then Exit Sub

    If Not candidates.Exists(key) Then candidates.Add key, obj
End Sub

Function CandidateKey(obj)
    CandidateKey = UCase(ObjectTypeName(obj) & "|" & ObjectName(obj) & "|" & ParentPath(obj, 4))
End Function

Sub AppendObjectReport(reportLines, obj, index)
    ListAdd reportLines, "------------------------------------------------------------"
    ListAdd reportLines, "Object #" & CStr(index)
    ListAdd reportLines, "Object name: " & ObjectName(obj)
    ListAdd reportLines, "Object type: " & ObjectTypeName(obj)
    ListAdd reportLines, "Parent path: " & ParentPath(obj, 8)
    ListAdd reportLines, "Part A: " & CandidatePartA(obj)
    ListAdd reportLines, "Part B: " & CandidatePartB(obj)
    ListAdd reportLines, "Weld type: " & CandidateValue(obj, Array("WeldType", "Weld Type", "Type"))
    ListAdd reportLines, "Weld size: " & CandidateValue(obj, Array("WeldSize", "Weld Size", "Size", "Throat"))
    ListAdd reportLines, "Weld length: " & CandidateValue(obj, Array("WeldLength", "Weld Length", "Length"))
    ListAdd reportLines, "Available parameters/properties:"
    Call AppendParameterReport(reportLines, obj, 80)
    ListAdd reportLines, ""
End Sub

Function CandidatePartA(obj)
    CandidatePartA = FirstNonEmpty(Array( _
        ObjectDescriptionFromObjectProperty(obj, "PartA"), _
        ObjectDescriptionFromObjectProperty(obj, "ConnectedPartA"), _
        ObjectDescriptionFromObjectProperty(obj, "FirstPart"), _
        ObjectDescriptionFromObjectProperty(obj, "Reference1"), _
        ObjectDescriptionFromObjectProperty(obj, "Support1"), _
        ObjectDescriptionFromObjectProperty(obj, "Element1")))
End Function

Function CandidatePartB(obj)
    CandidatePartB = FirstNonEmpty(Array( _
        ObjectDescriptionFromObjectProperty(obj, "PartB"), _
        ObjectDescriptionFromObjectProperty(obj, "ConnectedPartB"), _
        ObjectDescriptionFromObjectProperty(obj, "SecondPart"), _
        ObjectDescriptionFromObjectProperty(obj, "Reference2"), _
        ObjectDescriptionFromObjectProperty(obj, "Support2"), _
        ObjectDescriptionFromObjectProperty(obj, "Element2")))
End Function

Function ObjectDescriptionFromObjectProperty(obj, propertyName)
    ObjectDescriptionFromObjectProperty = ""

    ' VBScript has no CallByName, so the likely Weld Design property names are tried explicitly.
    Select Case UCase(CStr(propertyName))
        Case "PARTA"
            ObjectDescriptionFromObjectProperty = DescribePartAProperty(obj)
        Case "CONNECTEDPARTA"
            ObjectDescriptionFromObjectProperty = DescribeConnectedPartAProperty(obj)
        Case "FIRSTPART"
            ObjectDescriptionFromObjectProperty = DescribeFirstPartProperty(obj)
        Case "REFERENCE1"
            ObjectDescriptionFromObjectProperty = DescribeReference1Property(obj)
        Case "SUPPORT1"
            ObjectDescriptionFromObjectProperty = DescribeSupport1Property(obj)
        Case "ELEMENT1"
            ObjectDescriptionFromObjectProperty = DescribeElement1Property(obj)
        Case "PARTB"
            ObjectDescriptionFromObjectProperty = DescribePartBProperty(obj)
        Case "CONNECTEDPARTB"
            ObjectDescriptionFromObjectProperty = DescribeConnectedPartBProperty(obj)
        Case "SECONDPART"
            ObjectDescriptionFromObjectProperty = DescribeSecondPartProperty(obj)
        Case "REFERENCE2"
            ObjectDescriptionFromObjectProperty = DescribeReference2Property(obj)
        Case "SUPPORT2"
            ObjectDescriptionFromObjectProperty = DescribeSupport2Property(obj)
        Case "ELEMENT2"
            ObjectDescriptionFromObjectProperty = DescribeElement2Property(obj)
    End Select
End Function

Function DescribePartAProperty(obj)
    On Error Resume Next
    Dim refObj
    Set refObj = obj.PartA
    If Err.Number = 0 And Not refObj Is Nothing Then DescribePartAProperty = DescribeModelObject(refObj)
    Err.Clear
    On Error GoTo 0
End Function

Function DescribeConnectedPartAProperty(obj)
    On Error Resume Next
    Dim refObj
    Set refObj = obj.ConnectedPartA
    If Err.Number = 0 And Not refObj Is Nothing Then DescribeConnectedPartAProperty = DescribeModelObject(refObj)
    Err.Clear
    On Error GoTo 0
End Function

