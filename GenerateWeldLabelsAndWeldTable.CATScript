        "WeldID", _
        "PartA", _
        "PartB", _
        "BaseMaterial", _
        "MaterialDimensionThickness", _
        "WeldType", _
        "SizeGroove", _
        "GrooveAngle", _
        "RootGap", _
        "RootFace", _
        "NumberOfPasses", _
        "WeldLength_mm", _
        "WeldLength_m", _
        "WPS", _
        "WeldingProcess", _
        "FillerType", _
        "FillerTradeName", _
        "FillerDesignation", _
        "FillerDiameter", _
        "EstimatedFiller", _
        "EstimatedGasLiters", _
        "EstimatedGasBottles", _
        "VT", _
        "PT", _
        "UT", _
        "Remark")
End Function

Function HeadersForColumnKeys(columnKeys)
    Dim headers()
    Dim i
    ReDim headers(columnKeys.Count - 1)

    For i = 0 To columnKeys.Count - 1
        headers(i) = HeaderForColumnKey(CStr(columnKeys.Item(CStr(i))))
    Next

    HeadersForColumnKeys = headers
End Function

Function HeaderForColumnKey(columnKey)
    Select Case CStr(columnKey)
        Case "WeldID": HeaderForColumnKey = "Weld ID"
        Case "PartA": HeaderForColumnKey = "Part A"
        Case "PartB": HeaderForColumnKey = "Part B"
        Case "BaseMaterial": HeaderForColumnKey = "Osnovni materijal"
        Case "MaterialDimensionThickness": HeaderForColumnKey = "Dimenzija materijala / debljina"
        Case "WeldType": HeaderForColumnKey = "Weld Type"
        Case "SizeGroove": HeaderForColumnKey = "Size / Groove"
        Case "GrooveAngle": HeaderForColumnKey = "Groove Angle"
        Case "RootGap": HeaderForColumnKey = "Root Gap"
        Case "RootFace": HeaderForColumnKey = "Root Face"
        Case "NumberOfPasses": HeaderForColumnKey = "Number of Passes"
        Case "WeldLength_mm": HeaderForColumnKey = "Weld Length [mm]"
        Case "WeldLength_m": HeaderForColumnKey = "Weld Length [m]"
        Case "WPS": HeaderForColumnKey = "WPS"
        Case "WeldingProcess": HeaderForColumnKey = "Welding Process"
        Case "FillerType": HeaderForColumnKey = "Filler Type"
        Case "FillerTradeName": HeaderForColumnKey = "Filler Trade Name"
        Case "FillerDesignation": HeaderForColumnKey = "Filler Designation"
        Case "FillerDiameter": HeaderForColumnKey = "Filler Diameter"
        Case "EstimatedFiller": HeaderForColumnKey = "Estimated Filler [kg]"
        Case "EstimatedGasLiters": HeaderForColumnKey = "Procena gasa [L]"
        Case "EstimatedGasBottles": HeaderForColumnKey = "Procena gasa [boce 40L/200bar]"
        Case "VT": HeaderForColumnKey = "VT %"
        Case "PT": HeaderForColumnKey = "PT %"
        Case "UT": HeaderForColumnKey = "UT %"
        Case "Remark": HeaderForColumnKey = "Remark"
        Case Else: HeaderForColumnKey = CStr(columnKey)
    End Select
End Function

Function CommercialHeaders()
    CommercialHeaders = Array("Welding Process", _
                              "Filler Trade Name", _
                              "Filler Designation", _
                              "Filler Diameter", _
                              "Total Weld Length [m]", _
                              "Estimated Filler [kg]", _
                              "Procena gasa [L]", _
                              "Procena gasa [boce 40L/200bar]")
End Function

Function BuildWeldRows(welds, sortedKeys, columnKeys)
    Dim rows
    Set rows = NewList()

    Dim i
    Dim c
    Dim row()
    Dim weld

    For i = LBound(sortedKeys) To UBound(sortedKeys)
        Set weld = welds.Item(CStr(sortedKeys(i)))
        ReDim row(columnKeys.Count - 1)

        For c = 0 To columnKeys.Count - 1
            row(c) = GetColumnValue(weld, CStr(columnKeys.Item(CStr(c))))
        Next

        ListAdd rows, row
    Next

    Set BuildWeldRows = rows
End Function

Function GetColumnValue(weld, columnKey)
    Select Case CStr(columnKey)
        Case "WeldID"
            GetColumnValue = GetDictString(weld, "WeldID")
        Case "PartA"
            GetColumnValue = JoinPart(GetDictString(weld, "PartA_Number"), GetDictString(weld, "PartA_Name"))
        Case "PartB"
            GetColumnValue = JoinPart(GetDictString(weld, "PartB_Number"), GetDictString(weld, "PartB_Name"))
        Case "BaseMaterial"
            GetColumnValue = JoinDistinct(GetDictString(weld, "PartA_Material"), GetDictString(weld, "PartB_Material"))
        Case "MaterialDimensionThickness"
            GetColumnValue = JoinMaterialDimensions(weld)
        Case "WeldType"
            GetColumnValue = GetDictString(weld, "WeldType")
        Case "SizeGroove"
            GetColumnValue = SizeGrooveValue(weld)
        Case "GrooveAngle"
            GetColumnValue = GrooveAngleValue(weld)
        Case "RootGap"
            GetColumnValue = GetDictString(weld, "RootGap_mm")
        Case "RootFace"
            GetColumnValue = GetDictString(weld, "RootFace_mm")
        Case "NumberOfPasses"
            GetColumnValue = GetDictString(weld, "NumberOfPasses")
        Case "WeldLength_mm"
            GetColumnValue = GetDictString(weld, "WeldLength_mm")
        Case "WeldLength_m"
            GetColumnValue = GetDictString(weld, "WeldLength_m")
        Case "WPS"
            GetColumnValue = GetDictString(weld, "WPS")
        Case "WeldingProcess"
            GetColumnValue = GetDictString(weld, "WeldingProcess")
        Case "FillerType"
            GetColumnValue = GetDictString(weld, "FillerType")
        Case "FillerTradeName"
            GetColumnValue = GetDictString(weld, "FillerTradeName")
        Case "FillerDesignation"
            GetColumnValue = GetDictString(weld, "FillerDesignation")
        Case "FillerDiameter"
            GetColumnValue = GetDictString(weld, "FillerDiameter")
        Case "EstimatedFiller"
            GetColumnValue = GetDictString(weld, "EstimatedFillerConsumption_kg")
        Case "EstimatedGasLiters"
            GetColumnValue = Fmt2(GasLitersForWeld(weld))
        Case "EstimatedGasBottles"
            GetColumnValue = Fmt2(GasBottlesForWeld(weld))
        Case "VT"
            GetColumnValue = PercentValue(GetDictString(weld, "VT"))
        Case "PT"
            GetColumnValue = PercentValue(GetDictString(weld, "PT"))
        Case "UT"
            GetColumnValue = PercentValue(GetDictString(weld, "UT"))
        Case "Remark"
            GetColumnValue = GetDictString(weld, "Remark")
        Case Else
            GetColumnValue = ""
    End Select
End Function

Function SizeGrooveValue(weld)
    Dim weldType
    Dim value

    weldType = UCase(GetDictString(weld, "WeldType"))

    If IsButtWeldType(weldType) Then
        value = Trim(GetDictString(weld, "GrooveDepth"))
        If value <> "" Then
            If Left(UCase(value), 1) <> "S" Then value = "S" & value
        End If
        SizeGrooveValue = value
    Else
        SizeGrooveValue = GetDictString(weld, "WeldSize")
    End If
End Function

Function GrooveAngleValue(weld)
    Dim weldType
    weldType = UCase(GetDictString(weld, "WeldType"))

    If IsFilletWeldType(weldType) Then
        GrooveAngleValue = ""
    Else
        GrooveAngleValue = GetDictString(weld, "GrooveAngle")
    End If
End Function

Function IsFilletWeldType(weldType)
    IsFilletWeldType = (InStr(weldType, "FW") > 0 Or InStr(weldType, "FILLET") > 0)
End Function

Function IsButtWeldType(weldType)
    IsButtWeldType = (InStr(weldType, "BW") > 0 Or _
                      InStr(weldType, "BUTT") > 0 Or _
                      InStr(weldType, "GROOVE") > 0)
End Function

Function JoinPart(partNumber, partName)
    partNumber = Trim(CStr(partNumber))
    partName = Trim(CStr(partName))

    If partNumber <> "" And partName <> "" Then
        JoinPart = partNumber & " - " & partName
    ElseIf partNumber <> "" Then
        JoinPart = partNumber
    Else
        JoinPart = partName
    End If
End Function

Function JoinDistinct(valueA, valueB)
    valueA = Trim(CStr(valueA))
    valueB = Trim(CStr(valueB))

    If valueA <> "" And valueB <> "" Then
        If UCase(valueA) = UCase(valueB) Then
            JoinDistinct = valueA
        Else
            JoinDistinct = valueA & " / " & valueB
        End If
    ElseIf valueA <> "" Then
        JoinDistinct = valueA
    Else
        JoinDistinct = valueB
    End If
End Function

Function JoinMaterialDimensions(weld)
    Dim a
    Dim b

    a = JoinPartDimension(GetDictString(weld, "PartA_Dimension"), GetDictString(weld, "PartA_Thickness"))
    b = JoinPartDimension(GetDictString(weld, "PartB_Dimension"), GetDictString(weld, "PartB_Thickness"))

    JoinMaterialDimensions = JoinDistinct(a, b)
End Function

Function JoinPartDimension(dimensionValue, thicknessValue)
    dimensionValue = Trim(CStr(dimensionValue))
    thicknessValue = Trim(CStr(thicknessValue))

    If dimensionValue <> "" And thicknessValue <> "" Then
        JoinPartDimension = dimensionValue & " / t=" & thicknessValue
    ElseIf dimensionValue <> "" Then
        JoinPartDimension = dimensionValue
    ElseIf thicknessValue <> "" Then
        JoinPartDimension = "t=" & thicknessValue
    Else
        JoinPartDimension = ""
    End If
End Function

Function PercentValue(value)
    value = Trim(CStr(value))
    If value = "" Then
        PercentValue = ""
    ElseIf InStr(value, "%") > 0 Then
        PercentValue = value
    Else
        PercentValue = value & "%"
    End If
End Function

' ---------------------------------------------------------------------------
' Summary and grouping
' ---------------------------------------------------------------------------

Function BuildCommercialRows(welds, sortedKeys)
    Dim groups
    Set groups = BuildFillerGroups(welds, sortedKeys)

    Dim rows
    Set rows = NewList()

    Dim key
    Dim g
    Dim row

    For Each key In groups.Keys
        Set g = groups.Item(key)
        row = Array("", "", "", "", "", "", "", "")

        row(0) = GetDictString(g, "Process")
        row(1) = GetDictString(g, "TradeName")
        row(2) = GetDictString(g, "Designation")
        row(3) = GetDictString(g, "Diameter")
        row(4) = Fmt2(ToDouble(GetDictString(g, "Length_m")))
        row(5) = Fmt2(ToDouble(GetDictString(g, "Filler_kg")))
        row(6) = Fmt2(ToDouble(GetDictString(g, "Gas_L")))
        row(7) = Fmt2(ToDouble(GetDictString(g, "Gas_Bottles")))

        ListAdd rows, row
    Next

    Set BuildCommercialRows = rows
End Function

Function BuildFillerGroups(welds, sortedKeys)
    Dim groups
    Set groups = CreateObject("Scripting.Dictionary")
    groups.CompareMode = 1

    Dim i
    Dim weld
    Dim process
    Dim tradeName
    Dim designation
    Dim diameter
    Dim groupKey
    Dim g
    Dim lengthM
    Dim fillerKg
    Dim gasLiters
    Dim gasBottles

    For i = LBound(sortedKeys) To UBound(sortedKeys)
        Set weld = welds.Item(CStr(sortedKeys(i)))

        process = Trim(GetDictString(weld, "WeldingProcess"))
        tradeName = Trim(GetDictString(weld, "FillerTradeName"))
        designation = Trim(GetDictString(weld, "FillerDesignation"))
        diameter = Trim(GetDictString(weld, "FillerDiameter"))

        groupKey = UCase(process & "|" & tradeName & "|" & designation & "|" & diameter)

        If Not groups.Exists(groupKey) Then
            Set g = CreateObject("Scripting.Dictionary")
            g.CompareMode = 1
            g.Add "Process", process
            g.Add "TradeName", tradeName
            g.Add "Designation", designation
            g.Add "Diameter", diameter
            g.Add "Length_m", "0"
            g.Add "Filler_kg", "0"
            g.Add "Gas_L", "0"
            g.Add "Gas_Bottles", "0"
            groups.Add groupKey, g
        End If

        Set g = groups.Item(groupKey)

        lengthM = WeldLengthM(weld)
        fillerKg = ToDouble(GetDictString(weld, "EstimatedFillerConsumption_kg"))
        gasLiters = GasLitersForWeld(weld)
        gasBottles = GasBottlesForWeld(weld)

        SetDictString g, "Length_m", CStr(ToDouble(GetDictString(g, "Length_m")) + lengthM)
        SetDictString g, "Filler_kg", CStr(ToDouble(GetDictString(g, "Filler_kg")) + fillerKg)
        SetDictString g, "Gas_L", CStr(ToDouble(GetDictString(g, "Gas_L")) + gasLiters)
        SetDictString g, "Gas_Bottles", CStr(ToDouble(GetDictString(g, "Gas_Bottles")) + gasBottles)
    Next

    Set BuildFillerGroups = groups
End Function

Function BuildOverallSummaryRows(welds, sortedKeys)
    Dim rows
    Set rows = NewList()

    Dim totalLengthM
    Dim totalFillerKg
    Dim totalGasLiters
    Dim totalGasBottles
    Dim i
    Dim weld
    Dim row1(1)
    Dim row2(1)
    Dim row3(1)
    Dim row4(1)

    totalLengthM = 0.0
    totalFillerKg = 0.0
    totalGasLiters = 0.0
    totalGasBottles = 0.0

    For i = LBound(sortedKeys) To UBound(sortedKeys)
        Set weld = welds.Item(CStr(sortedKeys(i)))

        totalLengthM = totalLengthM + WeldLengthM(weld)
        totalFillerKg = totalFillerKg + ToDouble(GetDictString(weld, "EstimatedFillerConsumption_kg"))
        totalGasLiters = totalGasLiters + GasLitersForWeld(weld)
        totalGasBottles = totalGasBottles + GasBottlesForWeld(weld)
    Next

    row1(0) = "Ukupna duzina zavara [m]"
    row1(1) = Fmt2(totalLengthM) & " m"
    ListAdd rows, row1

    row2(0) = "Ukupna procenjena potrosnja dodatnog materijala [kg]"
    row2(1) = Fmt2(totalFillerKg) & " kg"
    ListAdd rows, row2

    row3(0) = "Ukupna procenjena potrosnja zastitnog gasa [L]"
    row3(1) = Fmt2(totalGasLiters) & " L"
    ListAdd rows, row3

    row4(0) = "Ukupna procenjena potrosnja zastitnog gasa [boce 40L/200bar]"
    row4(1) = Fmt2(totalGasBottles) & " boca 40L/200bar"
    ListAdd rows, row4

    Set BuildOverallSummaryRows = rows
End Function

Function WeldLengthM(weld)
    Dim lengthM
    Dim lengthMm

    lengthM = ToDouble(GetDictString(weld, "WeldLength_m"))

    If lengthM = 0.0 Then
        lengthMm = ToDouble(GetDictString(weld, "WeldLength_mm"))
        If lengthMm <> 0.0 Then lengthM = lengthMm / 1000.0
    End If

    WeldLengthM = lengthM
End Function

Function GasLitersForWeld(weld)
    Dim process
    Dim fillerKg
    Dim existingLiters
    Dim existingBottles

    process = Trim(GetDictString(weld, "WeldingProcess"))

    If process = "111" Then
        GasLitersForWeld = 0.0
        Exit Function
    End If

    If IsGasShieldedWeldingProcess(process) Then
        fillerKg = ToDouble(GetDictString(weld, "EstimatedFillerConsumption_kg"))
        GasLitersForWeld = fillerKg * 400.0
        Exit Function
    End If

    existingLiters = ToDouble(GetDictString(weld, "EstimatedGasLiters"))
    If existingLiters <> 0.0 Then
        GasLitersForWeld = existingLiters
        Exit Function
    End If

    existingBottles = ToDouble(GetDictString(weld, "EstimatedGasBottles_40L_200bar"))
    If existingBottles = 0.0 Then existingBottles = ToDouble(GetDictString(weld, "EstimatedGasBottles_200bar"))

    GasLitersForWeld = existingBottles * 8000.0
End Function

Function GasBottlesForWeld(weld)
    GasBottlesForWeld = GasLitersForWeld(weld) / 8000.0
End Function

Function IsGasShieldedWeldingProcess(weldingProcess)
    Select Case Trim(CStr(weldingProcess))
        Case "131", "135", "136", "141"
            IsGasShieldedWeldingProcess = True
        Case Else
            IsGasShieldedWeldingProcess = False
    End Select
End Function

Function GasForWeld(weld)
    GasForWeld = GasBottlesForWeld(weld)
End Function

' ---------------------------------------------------------------------------
' Drawing table creation
' ---------------------------------------------------------------------------

Function CreateOrGetSheet(drawingDoc, sheetName)
    Dim sheets
    Dim sheet
    Dim i

    Set CreateOrGetSheet = Nothing

    On Error Resume Next
    Set sheets = drawingDoc.Sheets
    On Error GoTo 0

    If sheets Is Nothing Then Exit Function

    For i = 1 To sheets.Count
        Set sheet = Nothing
        On Error Resume Next
        Set sheet = sheets.Item(i)
        On Error GoTo 0

        If Not sheet Is Nothing Then
            If UCase(CStr(sheet.Name)) = UCase(CStr(sheetName)) Then
                Set CreateOrGetSheet = sheet
                On Error Resume Next
                sheet.Activate
                On Error GoTo 0
                Exit Function
            End If
        End If
    Next

    On Error Resume Next
    Set sheet = sheets.Add(sheetName)
    If sheet Is Nothing Then Set sheet = sheets.Add()
    If Not sheet Is Nothing Then sheet.Name = sheetName
    If Not sheet Is Nothing Then sheet.Activate
    On Error GoTo 0

    Set CreateOrGetSheet = sheet
End Function

Function AddDrawingTable(sheet, title, headers, rows, x, y)
    AddDrawingTable = False

    If sheet Is Nothing Then Exit Function

    Dim view
    Set view = GetTableView(sheet)

    If view Is Nothing Then Exit Function

    Dim rowCount
    Dim colCount
    Dim tables
    Dim table
    Dim r
    Dim c
    Dim row
    Dim rowHeight

    colCount = UBound(headers) - LBound(headers) + 1
    rowCount = rows.Count + 1
    rowHeight = 5.5

    Set tables = Nothing
    Set table = Nothing

    On Error Resume Next
    Set tables = view.Tables
    Set table = tables.Add(CDbl(x), CDbl(y), rowCount, colCount, CDbl(rowHeight), 24.0)
    If Err.Number <> 0 Or table Is Nothing Then
        Err.Clear
        On Error GoTo 0
        AddDrawingTable = AddTextTableFallback(view, title, headers, rows, x, y)
        Exit Function
    End If

    Call AddTableTitleText(view, title, CDbl(x), CDbl(y) + 7.0)

    table.Name = SafeTableName(title)

    For c = 1 To colCount
        table.SetCellString 1, c, CStr(headers(c - 1))
        Call FormatTableCell(table, 1, c, 2.5, True)
    Next

    For r = 0 To rows.Count - 1
        row = rows.Item(CStr(r))
        For c = 1 To colCount
            table.SetCellString r + 2, c, CStr(row(c - 1))
            Call FormatTableCell(table, r + 2, c, 2.5, False)
        Next
    Next

    For c = 1 To colCount
        table.SetColumnSize c, TableColumnWidth(title, headers(c - 1), rows, c - 1)
    Next

    For r = 1 To rowCount
        table.SetRowSize r, CDbl(rowHeight)
    Next

    If Err.Number <> 0 Then Err.Clear
    On Error GoTo 0

    AddDrawingTable = True
End Function

Sub AddTableTitleText(view, title, x, y)
    Dim txt
    Set txt = Nothing

    On Error Resume Next
    Set txt = view.Texts.Add(CStr(title), CDbl(x), CDbl(y))
    If Not txt Is Nothing Then
        txt.Name = SafeTableName(title) & "_TITLE"
        txt.SetFontSize 0, 0, 3.0
        txt.SetFontStyle 0, 0, 1
    End If
    Err.Clear
    On Error GoTo 0
End Sub

Sub FormatTableCell(table, rowIndex, colIndex, fontSize, bold)
    Dim txt
    Set txt = Nothing

    On Error Resume Next
    Set txt = table.GetCellObject(CLng(rowIndex), CLng(colIndex))
    If Not txt Is Nothing Then
        txt.SetFontSize 0, 0, CDbl(fontSize)
        If CBool(bold) Then txt.SetFontStyle 0, 0, 1
    End If
    Err.Clear
    On Error GoTo 0
End Sub

Function AddTextTableFallback(view, title, headers, rows, x, y)
    AddTextTableFallback = False

    Dim textValue
    Dim r
    Dim row

    textValue = CStr(title) & vbCrLf & vbCrLf & Join(headers, " | ")

    For r = 0 To rows.Count - 1
        row = rows.Item(CStr(r))
        textValue = textValue & vbCrLf & Join(row, " | ")
    Next

    Dim txt
    Set txt = Nothing

    On Error Resume Next
    Set txt = view.Texts.Add(textValue, CDbl(x), CDbl(y))
    txt.Name = SafeTableName(title) & "_TEXT_FALLBACK"
    txt.SetFontSize 0, 0, 2.5
    If Err.Number = 0 Then AddTextTableFallback = True
    Err.Clear
    On Error GoTo 0
End Function

Function TableColumnWidth(tableTitle, header, rows, columnIndex)
    Dim estimated
    estimated = EstimateColumnWidth(header, rows, columnIndex)

    If CStr(tableTitle) = WeldJointTableTitle() Then
        Select Case CLng(columnIndex)
            Case 0: TableColumnWidth = BoundDouble(estimated, 20.0, 24.0)
            Case 1: TableColumnWidth = BoundDouble(estimated, 18.0, 22.0)
            Case 2: TableColumnWidth = BoundDouble(estimated, 30.0, 34.0)
            Case 3: TableColumnWidth = BoundDouble(estimated, 32.0, 38.0)
            Case 4: TableColumnWidth = BoundDouble(estimated, 22.0, 26.0)
            Case 5: TableColumnWidth = BoundDouble(estimated, 16.0, 18.0)
            Case 6: TableColumnWidth = BoundDouble(estimated, 55.0, 78.0)
            Case Else: TableColumnWidth = BoundDouble(estimated, 18.0, 45.0)
        End Select
        Exit Function
    End If

    If CStr(tableTitle) = MaterialConsumptionTableTitle() Then
        Select Case CLng(columnIndex)
            Case 0: TableColumnWidth = BoundDouble(estimated, 16.0, 18.0)
            Case 1: TableColumnWidth = BoundDouble(estimated, 30.0, 38.0)
            Case 2: TableColumnWidth = BoundDouble(estimated, 34.0, 46.0)
            Case 3: TableColumnWidth = BoundDouble(estimated, 8.0, 11.0)
            Case 4: TableColumnWidth = BoundDouble(estimated, 36.0, 42.0)
            Case 5: TableColumnWidth = BoundDouble(estimated, 34.0, 40.0)
            Case 6: TableColumnWidth = BoundDouble(estimated, 18.0, 24.0)
            Case 7: TableColumnWidth = BoundDouble(estimated, 34.0, 42.0)
            Case Else: TableColumnWidth = BoundDouble(estimated, 18.0, 45.0)
        End Select
        Exit Function
    End If

    TableColumnWidth = estimated
End Function

Function BoundDouble(value, minValue, maxValue)
    BoundDouble = CDbl(value)
    If BoundDouble < CDbl(minValue) Then BoundDouble = CDbl(minValue)
    If BoundDouble > CDbl(maxValue) Then BoundDouble = CDbl(maxValue)
End Function

Function TableTotalWidth(title, headers, rows)
    Dim total
    Dim i
    total = 0.0

    For i = LBound(headers) To UBound(headers)
        total = total + TableColumnWidth(title, headers(i), rows, i)
    Next

    TableTotalWidth = total
End Function

Function TableBlockHeight(rows)
    TableBlockHeight = 7.0 + ((CDbl(rows.Count) + 1.0) * 5.5)
End Function

Function TablesFitOnSheet(sheet, headersA, rowsA, headersB, rowsB, x, y)
    TablesFitOnSheet = True

    Dim sheetW
    Dim sheetH
    If Not GetSheetSizeMm(sheet, sheetW, sheetH) Then Exit Function

    Dim requiredWidth
    Dim requiredHeight

    requiredWidth = TableTotalWidth(WeldJointTableTitle(), headersA, rowsA)
    If TableTotalWidth(MaterialConsumptionTableTitle(), headersB, rowsB) > requiredWidth Then
        requiredWidth = TableTotalWidth(MaterialConsumptionTableTitle(), headersB, rowsB)
    End If

    requiredHeight = TableBlockHeight(rowsA) + 10.0 + TableBlockHeight(rowsB)

    If CDbl(x) + CDbl(requiredWidth) + 10.0 > CDbl(sheetW) Then TablesFitOnSheet = False
    If CDbl(y) - CDbl(requiredHeight) < 10.0 Then TablesFitOnSheet = False
End Function

Function DefaultTableTopY(sheet, fallbackY)
    DefaultTableTopY = CDbl(fallbackY)

    Dim sheetW
    Dim sheetH
    If GetSheetSizeMm(sheet, sheetW, sheetH) Then
        DefaultTableTopY = CDbl(sheetH) - 25.0
        If DefaultTableTopY < 80.0 Then DefaultTableTopY = CDbl(fallbackY)
    End If
End Function

Function GetSheetSizeMm(sheet, ByRef widthMm, ByRef heightMm)
    GetSheetSizeMm = False
    widthMm = 0.0
    heightMm = 0.0

    On Error Resume Next
    Err.Clear
    widthMm = CDbl(sheet.GetPaperWidth)
    heightMm = CDbl(sheet.GetPaperHeight)
    If Err.Number = 0 Then
        GetSheetSizeMm = True
        On Error GoTo 0
        Exit Function
    End If

    Err.Clear
    sheet.GetPaperWidth widthMm
    sheet.GetPaperHeight heightMm
    If Err.Number = 0 Then
        GetSheetSizeMm = True
        On Error GoTo 0
        Exit Function
    End If

    Err.Clear
    widthMm = CDbl(sheet.PaperWidth)
    heightMm = CDbl(sheet.PaperHeight)
    If Err.Number = 0 Then
        GetSheetSizeMm = True
        On Error GoTo 0
        Exit Function
    End If

    Err.Clear
    On Error GoTo 0
End Function

Function AddUnplacedLabelsTable(sheet, unplacedLabels)
    AddUnplacedLabelsTable = False

    If sheet Is Nothing Then Exit Function
    If unplacedLabels.Count = 0 Then Exit Function

    Dim rows
    Set rows = NewList()

    Dim i
    Dim row

    For i = 0 To unplacedLabels.Count - 1
        row = Array("")
        row(0) = CStr(unplacedLabels.Item(CStr(i)))
        ListAdd rows, row
    Next

    AddUnplacedLabelsTable = AddDrawingTable(sheet, _
                                             "UNPLACED WELD SYMBOLS / OZNAKE ZA RUCNI PREGLED", _
                                             Array("Weld ID"), rows, 20.0, 35.0)
End Function

Function PlaceUnplacedByFallbackGrid(sheet, unplacedLabels, labelChoice, ByRef placedCount, _
                                     ByRef textFallbackCount, labelDebugLines)
    PlaceUnplacedByFallbackGrid = 0

    If sheet Is Nothing Then Exit Function
    If unplacedLabels.Count = 0 Then Exit Function

    Dim view
    Set view = SelectFallbackViewForAutomaticLabels(sheet)
    If view Is Nothing Then Exit Function

    Dim remaining
    Set remaining = NewList()

    Dim xMin
    Dim xMax
    Dim yMin
    Dim yMax
    Dim startX
    Dim startY
    Dim stepX
    Dim stepY
    Dim cols

    stepX = 18.0
    stepY = 8.0
    cols = 4

    If GetViewBounds(view, xMin, xMax, yMin, yMax) Then
        startX = CDbl(xMin) + 10.0
        startY = CDbl(yMax) - 10.0
        If (CDbl(xMax) - CDbl(xMin)) > 100.0 Then cols = 5
        If (CDbl(xMax) - CDbl(xMin)) < 70.0 Then cols = 3
    Else
        startX = 20.0
        startY = 200.0
    End If

    Dim i
    Dim weldId
    Dim x
    Dim y
    Dim colIndex
    Dim rowIndex
    Dim method

    For i = 0 To unplacedLabels.Count - 1
        weldId = CStr(unplacedLabels.Item(CStr(i)))
        colIndex = i Mod cols
        rowIndex = Int(i / cols)
        x = startX + (CDbl(colIndex) * stepX)
        y = startY - (CDbl(rowIndex) * stepY)

        method = AddWeldSymbolOrTextAt(view, weldId, labelChoice, x, y)

        If method <> "" Then
            PlaceUnplacedByFallbackGrid = PlaceUnplacedByFallbackGrid + 1
            If method = "SYMBOL" Then placedCount = placedCount + 1
            If method = "TEXT" Then textFallbackCount = textFallbackCount + 1
            ListAdd labelDebugLines, weldId & ": fallback grid placement = " & method & " on view " & ObjectName(view)
        Else
            ListAdd remaining, weldId
            ListAdd labelDebugLines, weldId & ": fallback grid placement failed"
        End If
    Next

    Call ReplaceListContents(unplacedLabels, remaining)
End Function

Function AddWeldSymbolOrTextAt(view, weldId, labelChoice, x, y)
    AddWeldSymbolOrTextAt = ""

    Dim labelText
    labelText = FormatWeldLabel(weldId, labelChoice)

    If AddWeldSymbolAnnotation(view, labelText, weldId, x, y, x, y) Then
        AddWeldSymbolOrTextAt = "SYMBOL"
        Exit Function
    End If

    If AddWeldLabelText(view, labelText, weldId, x, y, x, y) Then
        AddWeldSymbolOrTextAt = "TEXT"
    End If
End Function

Function SelectFallbackViewForAutomaticLabels(sheet)
    Set SelectFallbackViewForAutomaticLabels = Nothing

    Dim defaultView
    Set defaultView = LargestCandidateView(sheet)

    If defaultView Is Nothing Then
        Set SelectFallbackViewForAutomaticLabels = FirstCandidateView(sheet)
        Exit Function
    End If

    Dim msg
    msg = "Select fallback view for automatic weld label placement" & vbCrLf & vbCrLf & _
          CandidateViewListText(sheet) & vbCrLf & _
          "Enter view number. Empty = largest/default view: " & ObjectName(defaultView)

    Dim inputValue
    inputValue = InputBox(msg, MACRO_NAME, "")

    If Trim(inputValue) <> "" And IsNumeric(inputValue) Then
        Set SelectFallbackViewForAutomaticLabels = CandidateViewByOrdinal(sheet, CLng(inputValue))
    End If

    If SelectFallbackViewForAutomaticLabels Is Nothing Then
        Set SelectFallbackViewForAutomaticLabels = defaultView
    End If
End Function

Function CandidateViewListText(sheet)
    CandidateViewListText = ""

    Dim views
    Set views = Nothing

    On Error Resume Next
    Set views = sheet.Views
    On Error GoTo 0

    If views Is Nothing Then Exit Function

    Dim i
    Dim ordinal
    Dim view
    ordinal = 0

    For i = 1 To views.Count
        Set view = Nothing
        On Error Resume Next
        Set view = views.Item(i)
        On Error GoTo 0

        If Not view Is Nothing Then
            If IsCandidateLabelView(view) Then
                ordinal = ordinal + 1
                If CandidateViewListText <> "" Then CandidateViewListText = CandidateViewListText & vbCrLf
                CandidateViewListText = CandidateViewListText & CStr(ordinal) & " = " & ObjectName(view)
            End If
        End If
    Next
End Function

Function CandidateViewByOrdinal(sheet, requestedOrdinal)
    Set CandidateViewByOrdinal = Nothing

    Dim views
    Set views = Nothing

    On Error Resume Next
    Set views = sheet.Views
    On Error GoTo 0

    If views Is Nothing Then Exit Function

    Dim i
    Dim ordinal
    Dim view
    ordinal = 0

    For i = 1 To views.Count
        Set view = Nothing
        On Error Resume Next
        Set view = views.Item(i)
        On Error GoTo 0

        If Not view Is Nothing Then
            If IsCandidateLabelView(view) Then
                ordinal = ordinal + 1
                If CLng(ordinal) = CLng(requestedOrdinal) Then
                    Set CandidateViewByOrdinal = view
                    Exit Function
                End If
            End If
        End If
    Next
End Function

Function LargestCandidateView(sheet)
    Set LargestCandidateView = Nothing

    Dim views
    Set views = Nothing

    On Error Resume Next
    Set views = sheet.Views
    On Error GoTo 0

    If views Is Nothing Then Exit Function

    Dim i
    Dim view
    Dim area
    Dim bestArea
    bestArea = -1.0

    For i = 1 To views.Count
        Set view = Nothing
        On Error Resume Next
        Set view = views.Item(i)
        On Error GoTo 0

        If Not view Is Nothing Then
            If IsCandidateLabelView(view) Then
                area = ViewArea(view)
                If area > bestArea Then
                    bestArea = area
                    Set LargestCandidateView = view
                End If
            End If
        End If
    Next
End Function

Function ViewArea(view)
    ViewArea = 0.0

    Dim xMin
    Dim xMax
    Dim yMin
    Dim yMax

    If GetViewBounds(view, xMin, xMax, yMin, yMax) Then
        ViewArea = Abs((CDbl(xMax) - CDbl(xMin)) * (CDbl(yMax) - CDbl(yMin)))
    End If
End Function

Function PlaceLabelsAsSideList(sheet, unplacedLabels, labelChoice)
    PlaceLabelsAsSideList = 0

    If sheet Is Nothing Then Exit Function
    If unplacedLabels.Count = 0 Then Exit Function

    Dim view
    Set view = FirstCandidateView(sheet)
    If view Is Nothing Then Exit Function

    Dim xMin
    Dim xMax
    Dim yMin
    Dim yMax
    Dim startX
    Dim startY

    If GetViewBounds(view, xMin, xMax, yMin, yMax) Then
        startX = CDbl(xMax) + 10.0
        startY = CDbl(yMax)
    Else
        startX = 20.0
        startY = 200.0
    End If

    Dim i
    Dim weldId
    Dim labelText
    Dim txt

    For i = 0 To unplacedLabels.Count - 1
        weldId = CStr(unplacedLabels.Item(CStr(i)))
        labelText = FormatWeldLabel(weldId, labelChoice)

        Set txt = Nothing
        On Error Resume Next
        Set txt = view.Texts.Add(labelText, startX, startY - (CDbl(i) * 6.0))
        If Err.Number = 0 And Not txt Is Nothing Then
            txt.Name = "SIDE_LABEL_" & weldId
            txt.SetFontSize 0, 0, DEFAULT_TEXT_HEIGHT_MM
            PlaceLabelsAsSideList = PlaceLabelsAsSideList + 1
        End If
        Err.Clear
        On Error GoTo 0
    Next
End Function

Function LabelPlacementFailureReason(modelGeometryFoundCount, projectedGeometryFoundCount, _
                                     labelPointCalculatedCount, projectionFailedCount)
    If CDbl(labelPointCalculatedCount) > 0 And CDbl(projectionFailedCount) > 0 Then
        LabelPlacementFailureReason = "Calibrated 3D to 2D view transform failed or no calibrated view was found."
        Exit Function
    End If

    If CDbl(modelGeometryFoundCount) > 0 And CDbl(projectedGeometryFoundCount) = 0 Then
        LabelPlacementFailureReason = "WELD_MAP geometry was found, but drawing view calibration is missing or does not match."
        Exit Function
    End If

    If CDbl(modelGeometryFoundCount) > 0 Then
        LabelPlacementFailureReason = "WELD_MAP geometry was found, but calibrated placement still failed."
        Exit Function
    End If

    LabelPlacementFailureReason = "No WELD_MAP anchor/geometry point could be used for calibrated placement."
End Function

Function WriteLabelDebugLog(drawingDoc, labelDebugLines)
    WriteLabelDebugLog = ""

    If labelDebugLines Is Nothing Then Exit Function
    If labelDebugLines.Count = 0 Then Exit Function

    Dim folderPath
    folderPath = DrawingFolder(drawingDoc)

    If Trim(folderPath) = "" Then
        On Error Resume Next
        folderPath = CreateObject("WScript.Shell").SpecialFolders("Desktop")
        If Err.Number <> 0 Then
            Err.Clear
            folderPath = ""
        End If
        On Error GoTo 0
    End If

    If Trim(folderPath) = "" Then Exit Function

    Dim fso
    Dim filePath
    Dim file
    Dim i

    Set fso = CreateObject("Scripting.FileSystemObject")
    filePath = fso.BuildPath(folderPath, "drawing_weld_label_debug.txt")

    On Error Resume Next
    Set file = fso.CreateTextFile(filePath, True, False)
    If Err.Number <> 0 Or file Is Nothing Then
        Err.Clear
        On Error GoTo 0
        Exit Function
    End If

    file.WriteLine "Drawing weld label debug"
    file.WriteLine "Generated: " & CStr(Now)
    file.WriteLine ""

    For i = 0 To labelDebugLines.Count - 1
        file.WriteLine CStr(labelDebugLines.Item(CStr(i)))
    Next

    file.Close
    On Error GoTo 0

    WriteLabelDebugLog = filePath
End Function

Function GetTableView(sheet)
    Set GetTableView = Nothing

    Dim views
    Dim view
    Dim i
    Dim nameValue

    On Error Resume Next
    Set views = sheet.Views
    On Error GoTo 0

    If views Is Nothing Then Exit Function

    For i = 1 To views.Count
        Set view = Nothing
        nameValue = ""

        On Error Resume Next
        Set view = views.Item(i)
        nameValue = UCase(CStr(view.Name))
        On Error GoTo 0

        If Not view Is Nothing Then
            If InStr(nameValue, "MAIN") > 0 Then
                Set GetTableView = view
                Exit Function
            End If
        End If
    Next

    On Error Resume Next
    Set GetTableView = views.ActiveView
    On Error GoTo 0

    If GetTableView Is Nothing Then
        On Error Resume Next
        Set GetTableView = views.Item(1)
        On Error GoTo 0
    End If
End Function

Function EstimateColumnWidth(header, rows, columnIndex)
    Dim maxLen
    Dim r
    Dim row
    Dim value

    maxLen = Len(CStr(header))

    For r = 0 To rows.Count - 1
        row = rows.Item(CStr(r))
        value = CStr(row(columnIndex))
        If Len(value) > maxLen Then maxLen = Len(value)
    Next

    EstimateColumnWidth = 12.0 + (CDbl(maxLen) * 2.1)
    If EstimateColumnWidth < 22.0 Then EstimateColumnWidth = 22.0
    If EstimateColumnWidth > 70.0 Then EstimateColumnWidth = 70.0
End Function

Function SafeTableName(value)
    Dim s
    s = UCase(CStr(value))
    s = Replace(s, " ", "_")
    s = Replace(s, "/", "_")
    s = Replace(s, "\", "_")
    s = Replace(s, ":", "_")
    s = Replace(s, "-", "_")
    s = Replace(s, "__", "_")

    If Len(s) > 60 Then s = Left(s, 60)
    SafeTableName = s
End Function

' ---------------------------------------------------------------------------
' CSV export
' ---------------------------------------------------------------------------

Sub ExportCsvFiles(drawingDoc, tableHeaders, tableRows, consumptionHeaders, consumptionRows)
    Dim folderPath
    folderPath = DrawingFolder(drawingDoc)

    If folderPath = "" Then
        folderPath = AskString("Drawing is not saved. Enter folder path for CSV export:", "")
    End If

    If Trim(folderPath) = "" Then Exit Sub

    Dim fso
    Set fso = CreateObject("Scripting.FileSystemObject")

    If Not fso.FolderExists(folderPath) Then
        MsgBox "CSV folder does not exist:" & vbCrLf & folderPath, vbExclamation, MACRO_NAME
        Exit Sub
    End If

    Dim tablePath
    Dim consumptionPath

    tablePath = fso.BuildPath(folderPath, "drawing_weld_table.csv")
    consumptionPath = fso.BuildPath(folderPath, "drawing_weld_consumption.csv")

    Call WriteCsv(tablePath, tableHeaders, tableRows)
    Call WriteCsv(consumptionPath, consumptionHeaders, consumptionRows)

    MsgBox "CSV export completed:" & vbCrLf & tablePath & vbCrLf & consumptionPath, _
           vbInformation, MACRO_NAME
End Sub

Function DrawingFolder(drawingDoc)
    DrawingFolder = ""

    Dim fullName
    Dim fso

    fullName = ""
    On Error Resume Next
    fullName = CStr(drawingDoc.FullName)
    On Error GoTo 0

    If fullName = "" Then Exit Function

    Set fso = CreateObject("Scripting.FileSystemObject")
    DrawingFolder = fso.GetParentFolderName(fullName)
End Function

Sub WriteCsv(filePath, headers, rows)
    Dim fso
    Dim ts
    Dim r
    Dim row

    Set fso = CreateObject("Scripting.FileSystemObject")
    Set ts = fso.CreateTextFile(filePath, True, False)

    ts.WriteLine CsvLine(headers)

    For r = 0 To rows.Count - 1
        row = rows.Item(CStr(r))
        ts.WriteLine CsvLine(row)
    Next

    ts.Close
End Sub

Function CsvLine(values)
    Dim i
    Dim line
    line = ""

    For i = LBound(values) To UBound(values)
        If i > LBound(values) Then line = line & ";"
        line = line & CsvCell(CStr(values(i)))
    Next

    CsvLine = line
End Function

Function CsvCell(value)
    value = Replace(CStr(value), """", """""")

    If InStr(value, ";") > 0 Or InStr(value, """") > 0 Or _
       InStr(value, vbCr) > 0 Or InStr(value, vbLf) > 0 Then
        CsvCell = """" & value & """"
    Else
        CsvCell = value
    End If
End Function

' ---------------------------------------------------------------------------
' Generic helpers
' ---------------------------------------------------------------------------

Function NewList()
    Dim list
    Set list = CreateObject("Scripting.Dictionary")
    Set NewList = list
End Function

Function JoinArray(values, delimiter)
    Dim s
    Dim i
    s = ""

    For i = LBound(values) To UBound(values)
        If s <> "" Then s = s & CStr(delimiter)
        s = s & CStr(values(i))
    Next

    JoinArray = s
End Function

Sub ListAdd(list, value)
    list.Add CStr(list.Count), value
End Sub

Sub ListAddUnique(list, value)
    If Not ListContains(list, value) Then
        ListAdd list, value
    End If
End Sub

Sub ReplaceListContents(targetList, sourceList)
    targetList.RemoveAll

    Dim i
    For i = 0 To sourceList.Count - 1
        ListAdd targetList, sourceList.Item(CStr(i))
    Next
End Sub

Function ListContains(list, value)
    ListContains = False

    Dim i
    For i = 0 To list.Count - 1
        If CStr(list.Item(CStr(i))) = CStr(value) Then
            ListContains = True
            Exit Function
        End If
    Next
End Function

Function ListToMultilineText(list)
    Dim s
    Dim i
    s = ""

    For i = 0 To list.Count - 1
        If s <> "" Then s = s & vbCrLf
        s = s & CStr(list.Item(CStr(i)))
    Next

    ListToMultilineText = s
End Function

Function GetDictString(dict, key)
    GetDictString = ""
    If dict Is Nothing Then Exit Function
    If dict.Exists(CStr(key)) Then GetDictString = CStr(dict.Item(CStr(key)))
End Function

Sub SetDictString(dict, key, value)
    If dict.Exists(CStr(key)) Then
        dict.Item(CStr(key)) = CStr(value)
    Else
        dict.Add CStr(key), CStr(value)
    End If
End Sub

Function AskString(prompt, defaultValue)
    AskString = InputBox(prompt, MACRO_NAME, CStr(defaultValue))
End Function

Function AskYesNo(prompt, defaultYes)
    Dim buttons
    Dim result

    If defaultYes Then
        buttons = vbQuestion + vbYesNo + vbDefaultButton1
    Else
        buttons = vbQuestion + vbYesNo + vbDefaultButton2
    End If

    result = MsgBox(prompt, buttons, MACRO_NAME)
    AskYesNo = (result = vbYes)
End Function

Function AskNumber(prompt, defaultValue)
    Dim inputValue
    inputValue = InputBox(prompt, MACRO_NAME, CStr(defaultValue))

    If Trim(inputValue) = "" Then
        AskNumber = CDbl(defaultValue)
    Else
        AskNumber = ToDouble(inputValue)
    End If
End Function

Function ToDouble(value)
    Dim s
    Dim i
    Dim ch
    Dim cleaned
    Dim decimalDot
    Dim decimalComma

    s = Trim(CStr(value))
    cleaned = ""

    For i = 1 To Len(s)
        ch = Mid(s, i, 1)
        If (ch >= "0" And ch <= "9") Or ch = "." Or ch = "," Or ch = "-" Then
            cleaned = cleaned & ch
        End If
    Next

    If cleaned = "" Or cleaned = "-" Then
        ToDouble = 0.0
        Exit Function
    End If

    decimalDot = InStrRev(cleaned, ".")
    decimalComma = InStrRev(cleaned, ",")

    If decimalDot > 0 And decimalComma > 0 Then
        If decimalDot > decimalComma Then
            cleaned = Replace(cleaned, ",", "")
        Else
            cleaned = Replace(cleaned, ".", "")
            cleaned = Replace(cleaned, ",", ".")
        End If
    ElseIf decimalComma > 0 Then
        cleaned = Replace(cleaned, ",", ".")
    End If

    On Error Resume Next
    Err.Clear
    ToDouble = CDbl(cleaned)
    If Err.Number <> 0 Then
        Err.Clear
        ToDouble = CDbl(Replace(cleaned, ".", ","))
    End If
    If Err.Number <> 0 Then
        Err.Clear
        ToDouble = 0.0
    End If
    On Error GoTo 0
End Function

Function Fmt2(value)
    Dim s
    On Error Resume Next
    s = CStr(Round(CDbl(value), 2))
    If Err.Number <> 0 Then
        Err.Clear
        s = "0"
    End If
    On Error GoTo 0

    If InStr(s, ",") > 0 Then s = Replace(s, ",", ".")
    If InStr(s, ".") = 0 Then s = s & ".00"

    Dim decimalPart
    decimalPart = Split(s, ".")
    If UBound(decimalPart) = 1 Then
        If Len(decimalPart(1)) = 1 Then s = s & "0"
    End If

    Fmt2 = s
End Function

Function Fmt0(value)
    Dim s
    On Error Resume Next
    s = CStr(Round(CDbl(value), 0))
    If Err.Number <> 0 Then
        Err.Clear
        s = "0"
    End If
    On Error GoTo 0

    If InStr(s, ",") > 0 Then s = Replace(s, ",", ".")
    If InStr(s, ".") > 0 Then s = Split(s, ".")(0)

    Fmt0 = s
End Function

Function PadLeft(value, totalLength, padChar)
    Dim s
    s = CStr(value)

    Do While Len(s) < CLng(totalLength)
        s = CStr(padChar) & s
    Loop

    PadLeft = s
End Function

Function YesNoText(value)
    If CBool(value) Then
        YesNoText = "Yes"
    Else
        YesNoText = "No"
    End If
End Function
